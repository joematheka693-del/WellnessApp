<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:background="#663807"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Exercises"
            android:textSize="30sp"
            android:textStyle="bold"
            android:textAlignment="center"
            android:textColor="#FFFFFF"
            android:padding="12dp"
            android:layout_marginBottom="20dp"/>

        <!-- ===== Exercise Card 1 ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="12dp"
            android:layout_marginBottom="16dp"
            android:elevation="4dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:src="@drawable/pushup"
                android:scaleType="centerCrop"/>

            <TextView
                android:text="Push Ups"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="#000000"
                android:layout_marginTop="8dp"/>

            <TextView
                android:text="Strengthens chest and arms."
                android:textColor="#555555"/>

            <Button
                android:id="@+id/btnPushUps"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="View Exercise"
                android:backgroundTint="#0E8797"
                android:textColor="#FFFFFF"
                android:layout_marginTop="8dp"/>
        </LinearLayout>

        <!-- ===== Exercise Card 2 ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="12dp"
            android:layout_marginBottom="16dp"
            android:elevation="4dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:src="@drawable/squat"
                android:scaleType="centerCrop"/>

            <TextView
                android:text="Squats"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="#000000"
                android:layout_marginTop="8dp"/>

            <TextView
                android:text="Builds leg strength."
                android:textColor="#555555"/>

            <Button
                android:id="@+id/btnSquats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="View Exercise"
                android:backgroundTint="#0E8797"
                android:textColor="#FFFFFF"
                android:layout_marginTop="8dp"/>
        </LinearLayout>

        <!-- ===== Exercise Card 3 ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="12dp"
            android:layout_marginBottom="16dp"
            android:elevation="4dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:src="@drawable/plank"
                android:scaleType="centerCrop"/>

            <TextView
                android:text="Plank"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="#000000"
                android:layout_marginTop="8dp"/>

            <TextView
                android:text="Improves core strength."
                android:textColor="#555555"/>

            <Button
                android:id="@+id/btnPlank"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="View Exercise"
                android:backgroundTint="#0E8797"
                android:textColor="#FFFFFF"
                android:layout_marginTop="8dp"/>
        </LinearLayout>

    </LinearLayout>

</ScrollView>