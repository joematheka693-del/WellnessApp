<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MeditationActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#323">  <!-- semi-transparent overlay -->

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Meditation"
            android:textSize="25sp"
            android:textAlignment="center"
            android:textStyle="bold"
            android:background="@drawable/shape"
            android:padding="10dp"
            android:textColor="#0E8797" />

        <!-- Image -->
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="250dp"
            android:src="@drawable/meditation"
            android:scaleType="centerCrop" />

        <!-- Content -->
        <TextView
            android:id="@+id/meditationText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Meditation\n\nMeditation is a simple practice that helps calm your mind, reduce stress, and improve your overall well-being.\n\nBenefits:\n\n1. Reduces stress\n2. Improves focus\n3. Helps you sleep better\n4. Increases self-awareness\n5. Promotes emotional balance\n\nSimple Steps:\n\n• Sit comfortably\n• Close your eyes\n• Focus on your breathing\n• Relax for a few minutes daily"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:background="#2C6846"
            android:padding="16dp"/>

    </LinearLayout>

</ScrollView>