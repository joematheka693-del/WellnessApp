<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:background="#2E4057"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".WeeklyGoalsActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Weekly Goals"
            android:textSize="25sp"
            android:textAlignment="center"
            android:textStyle="bold"
            android:background="@drawable/shape"
            android:padding="10dp"
            android:textColor="#0E8797"
            android:layout_marginBottom="16dp"/>

        <!-- Image -->
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:src="@drawable/goals"
            android:scaleType="centerCrop"
            android:layout_marginBottom="16dp"/>

        <!-- Goals List -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Your Weekly Goals:\n\n1. Drink 2 liters of water daily\n2. Complete 3 exercise sessions\n3. Eat 5 servings of fruits/vegetables daily\n4. Sleep at least 7 hours per night\n5. Track your progress every day\n6. Prepare healthy meals in advance\n7. Avoid sugary drinks\n8. Meditate for 10 minutes daily"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:padding="16dp"/>

        <!-- Optional: Add CheckBoxes if you want tracking -->
        <!--
        <CheckBox
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Drink 2 liters of water daily"
            android:textColor="#FFFFFF"/>
        -->

    </LinearLayout>

</ScrollView>